    "start": "NODE_ENV=production node dist/server.js",
    "test:ui": "vitest --ui",
    "test:ai": "AI_TESTS=true vitest",
    "migration:generate": "npx typeorm-ts-node-esm migration:generate src/migrations/InitialSchema -d src/data-source.cli.ts",
    "migration:run": "npx typeorm-ts-node-esm migration:run -d src/data-source.cli.ts",
    "migration:revert": "npx typeorm-ts-node-esm migration:revert -d src/data-source.cli.ts"
  },
